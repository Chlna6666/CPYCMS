SECRET_KEY=change-me-in-production
CPYCMS_HOST=0.0.0.0
CPYCMS_PORT=5000
CPYCMS_DEBUG=1
CPYCMS_ALLOWED_HOSTS=127.0.0.1,localhost
CPYCMS_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000,http://127.0.0.1:3000,http://localhost:3000
CPYCMS_TRUST_PROXY_HEADERS=0
CPYCMS_USE_X_FORWARDED_HOST=0
CPYCMS_DATABASE_FILE=../cpycms.db
CPYCMS_UPLOAD_FOLDER=../uploads
CPYCMS_USE_VITE_DEV_SERVER=1
CPYCMS_AUTO_START_VITE=1
CPYCMS_FRONTEND_DEV_SERVER_URL=http://127.0.0.1:3000
CPYCMS_VITE_STARTUP_TIMEOUT=20
CPYCMS_LOG_LEVEL=INFO
CPYCMS_LOG_DIR=../logs
CPYCMS_LOG_COLOR=auto
CPYCMS_SLOW_REQUEST_MS=800
CPYCMS_LOG_BACKUP_DAYS=14
CPYCMS_LOG_MAX_TOTAL_MB=256
CPYCMS_THREADED=1
