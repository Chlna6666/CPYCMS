# CPYCMS runtime configuration
SECRET_KEY=change-me-in-production
CPYCMS_HOST=0.0.0.0
CPYCMS_PORT=5000
CPYCMS_DEBUG=0
CPYCMS_ALLOWED_HOSTS=*
CPYCMS_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
CPYCMS_DATABASE_FILE=/app/data/cpycms.db
CPYCMS_SQLITE_BUSY_TIMEOUT_MS=5000
CPYCMS_SQLITE_CACHE_KB=20000
CPYCMS_REFRESH_SEARCH_INDEX_ON_STARTUP=0
CPYCMS_UPLOAD_FOLDER=/app/uploads
CPYCMS_FRONTEND_DIST=/app/frontend/dist
CPYCMS_LOG_LEVEL=INFO
CPYCMS_LOG_DIR=/app/logs
CPYCMS_LOG_COLOR=auto
CPYCMS_SLOW_REQUEST_MS=800
CPYCMS_LOG_BACKUP_DAYS=14
CPYCMS_LOG_MAX_TOTAL_MB=256

# Docker compose host ports
BACKEND_PORT=5000

# Optional Gunicorn overrides. Leave empty to auto-size with SQLite-friendly defaults.
GUNICORN_WORKERS=
GUNICORN_THREADS=
GUNICORN_TIMEOUT=120
